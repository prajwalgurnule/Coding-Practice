// Count of Laptop minimum Charge
import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt(); // Mininum charge required
        
        ArrayList<Integer> arr = new ArrayList<>();
        while (sc.hasNextInt()) {
            arr.add(sc.nextInt());
        }
        int count = 0;
        for(int i=0; i<arr.size(); i++){
            if (arr.get(i) > n) count ++;
        }
        System.out.println(count);
    }
}

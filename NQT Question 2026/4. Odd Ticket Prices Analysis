// Odd Ticket Prices Analysis
import java.util.*;
class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int[] arr = new int[n];
        for (int i=0; i<n; i++){
            arr[i] = sc.nextInt();
        }
        
        int sum = 0, count = 0;
        for (int i : arr){
            if(i % 2 != 0){
                sum += i;
                count ++;
            }
        }
        double avg = (count == 0) ? 0 : (double)sum/count;
        System.out.println(sum+" "+count+" "+avg);
    }
}

class Main {
    public static void main(String[] args) {
        double a = 2, r = 3;
        int n = 5;
        System.out.println("Sum of N natural number - "+sumofGP(a,r,n));
    }
    
    public static double sumofGP(double a, double r, int n) {
        if (r == 1) return a*n;
        else return a*(Math.pow(a,r) - 1) / (r - 1);
    }
}

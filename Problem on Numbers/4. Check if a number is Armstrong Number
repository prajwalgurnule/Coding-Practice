class Main {
    public static void main(String[] args) {
        int num = 153;
        if (isArmstrong(num)) System.out.println(num+" is an Armstrong");
        else System.out.println(num+" is not an Armstrong");
    }
    
    public static boolean isArmstrong(int num){
        int k =  String.valueOf(num).length();
        int n = num, sum = 0;
        while (n > 0){
            int ld = n % 10;             // Last digit
            sum += Math.pow(ld, k);      // Add ld^k
            n /= 10;                     // Remove digit
        }
        return sum == num;
    }
}

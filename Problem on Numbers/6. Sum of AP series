class Main {
    public static void main(String[] args) {
        float a = 1.5f, d = 3f;
        int n = 5;
        System.out.println("Sum of N natural number - "+sumofAP(a,d,n));
    }
    
    public static float sumofAP(float a, float d, int n) {
        float sum = 0;
        for(int i=1; i<=n; i++){
            sum += a;
            a += d;
        } 
        return sum;
    }
}
